#!/bin/bash
set -euo pipefail

# omarchy-secureboot - Secure Boot setup for Omarchy with Windows dual-boot support.
# Ongoing maintenance handled by zz-sbctl.hook + zzz-omarchy-secureboot.hook.

# Resolve lib directory (handles symlinks from /usr/local/bin -> /usr/local/lib)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib/omarchy-secureboot"
# Fallback for development (running from repo checkout)
[[ -d "$LIB_DIR" ]] || LIB_DIR="${SCRIPT_DIR}/../lib"

for lib in common checks discover sign enroll windows status; do
  # shellcheck source=/dev/null
  source "${LIB_DIR}/${lib}.sh"
done

# --- Commands ----------------------------------------------------------------

cmd_setup() {
  header "Secure Boot Setup"
  check_deps
  check_efi_mode
  check_root "setup"
  require_gum

  create_keys

  disable_limine_verification || true
  refresh_limine_config || die "Could not regenerate Limine config"

  clean_stale_entries

  echo
  echo -e "  ${BOLD}Signing EFI files${NC}"
  local sign_rc=0
  sign_all_efi || sign_rc=$?

  restore_windows_entry || true
  upgrade_windows_entry || true
  enroll_limine_config || die "Could not enroll Limine config checksum"

  echo
  echo -e "  ${BOLD}Next steps${NC}"
  echo "    1. Reboot into BIOS/UEFI firmware settings"
  echo "    2. Enable Setup Mode (clear/reset Secure Boot keys)"
  echo "    3. Save and exit BIOS"
  echo -e "    4. Run ${BOLD}sudo omarchy-secureboot enroll${NC}"
  echo

  return $sign_rc
}

cmd_enroll() {
  header "Key Enrollment"
  check_deps
  check_efi_mode
  check_root "enroll"
  require_gum
  enroll_keys
}

cmd_windows() {
  check_deps
  check_root "windows"
  require_gum
  add_windows_entry
}

cmd_sign() {
  check_deps
  check_root "sign"
  qheader "Signing EFI Files"
  disable_limine_verification || true
  refresh_limine_config || die "Could not regenerate Limine config"
  clean_stale_entries
  local sign_rc=0
  sign_all_efi || sign_rc=$?
  restore_windows_entry || true
  upgrade_windows_entry || true
  enroll_limine_config || die "Could not enroll Limine config checksum"
  return $sign_rc
}

cmd_status() {
  check_core_deps
  show_status
}

cmd_help() {
  header "Secure Boot for Omarchy"
  echo "  Enable Secure Boot with Windows dual-boot support."
  echo -e "  After setup, ${DIM}zz-sbctl.hook${NC} + ${DIM}zzz-omarchy-secureboot.hook${NC} handle re-signing."
  echo
  echo -e "  ${BOLD}Usage${NC}   sudo omarchy-secureboot <command>"
  echo
  echo -e "  ${BOLD}Commands${NC}"
  echo "    setup       Configure Limine Secure Boot state and sign EFI files"
  echo "    enroll      Enroll keys into firmware (requires Setup Mode)"
  echo "    windows     Add a Windows EFI entry and enroll the config"
  echo "    status      Show Secure Boot status and file verification"
  echo "    sign        Refresh Limine config, enroll it, and sign EFI files"
  echo "    help        Show this help"
  echo "    version     Show version"
  echo
  echo -e "  ${BOLD}Workflow${NC}"
  echo "    1. sudo omarchy-secureboot setup"
  echo "    2. Reboot -> BIOS -> enable Setup Mode (clear keys)"
  echo "    3. sudo omarchy-secureboot enroll"
  echo "    4. Reboot -> BIOS -> enable Secure Boot"
  echo "    5. sudo omarchy-secureboot windows   (if dual-booting)"
  echo
}

# --- Dispatch ----------------------------------------------------------------

# Parse global flags
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --quiet) QUIET=true; shift ;;
    *)       break ;;
  esac
done

case "${1:-}" in
  setup)    cmd_setup ;;
  enroll)   cmd_enroll ;;
  windows)  cmd_windows ;;
  sign)     cmd_sign ;;
  status)   cmd_status ;;
  help|--help|-h)  cmd_help ;;
  version|--version|-v) echo "omarchy-secureboot ${VERSION}" ;;
  *)
    cmd_help
    [[ -n "${1:-}" ]] && { fail "Unknown command: $1"; echo; exit 1; }
    ;;
esac
