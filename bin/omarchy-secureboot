#!/bin/bash
set -euo pipefail

# omarchy-secureboot - Omarchy Secure Boot: sbctl signing, Limine enrollment, pacman hook, and Windows BootNext handoff.
# Ongoing maintenance handled by zz-omarchy-secureboot-cleanup.hook, zz-sbctl.hook,
# zzz-omarchy-secureboot.hook, and the repo-owned watcher for non-pacman boot drift.

# Resolve lib directory (handles symlinks from /usr/local/bin -> /usr/local/lib)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib/omarchy-secureboot"
# Fallback for development (running from repo checkout)
[[ -d "$LIB_DIR" ]] || LIB_DIR="${SCRIPT_DIR}/../lib"

for lib in common checks discover sign enroll windows status; do
  # shellcheck source=/dev/null
  source "${LIB_DIR}/${lib}.sh"
done

# --- Commands ----------------------------------------------------------------

cmd_setup() {
  header "Secure Boot Setup"
  check_deps
  check_efi_mode
  check_root "setup"
  require_gum

  create_keys
  with_repair_lock

  ensure_limine_secure_boot_settings || die "Could not update Limine Secure Boot settings"
  refresh_limine_config || die "Could not regenerate Limine config"

  snapshot_limine_conf_hash
  ensure_windows_boot_entry || true
  reenroll_limine_config_if_changed || die "Could not enroll Limine config checksum"

  clean_stale_entries

  echo
  echo -e "  ${BOLD}Signing EFI files${NC}"
  local sign_rc=0
  sign_all_efi || sign_rc=$?

  echo
  echo -e "  ${BOLD}Next steps${NC}"
  echo "    1. Reboot into BIOS/UEFI firmware settings"
  echo "    2. Enable Setup Mode (clear/reset Secure Boot keys)"
  echo "    3. Save and exit BIOS"
  echo -e "    4. Run ${BOLD}sudo omarchy-secureboot enroll${NC}"
  echo

  return $sign_rc
}

cmd_enroll() {
  header "Key Enrollment"
  check_deps
  check_efi_mode
  check_root "enroll"
  require_gum
  enroll_keys
}

cmd_windows() {
  check_root "windows"
  if ! grep -q "$WINDOWS_ENTRY_MARKER" "$LIMINE_CONF" 2>/dev/null; then
    check_deps
    require_gum
    add_windows_boot_entry
    return $?
  fi
  header "Boot to Windows"
  reboot_to_windows
}

cmd_cleanup() {
  check_core_deps
  check_root "cleanup"
  with_repair_lock
  clean_stale_entries
}

cmd_sign() {
  check_deps
  check_root "sign"
  with_repair_lock
  qheader "Signing EFI Files"
  ensure_limine_secure_boot_settings || die "Could not update Limine Secure Boot settings"
  snapshot_limine_conf_hash
  ensure_windows_boot_entry || true
  reenroll_limine_config_if_changed || die "Could not enroll Limine config checksum"
  clean_stale_entries
  local sign_rc=0
  sign_all_efi || sign_rc=$?
  return $sign_rc
}

cmd_status() {
  check_core_deps
  show_status
}

cmd_help() {
  header "omarchy-secureboot"
  echo "  Omarchy Secure Boot: sbctl signing, Limine enrollment, pacman hook, and Windows BootNext handoff."
  echo -e "  After setup, ${DIM}zz-omarchy-secureboot-cleanup.hook${NC}, ${DIM}zz-sbctl.hook${NC}, ${DIM}zzz-omarchy-secureboot.hook${NC},"
  echo -e "  and ${DIM}omarchy-secureboot-watcher.path${NC} keep Secure Boot state repaired."
  echo
  echo -e "  ${BOLD}Usage${NC}   sudo omarchy-secureboot <command>"
  echo
  echo -e "  ${BOLD}Commands${NC}"
  echo "    setup       Set Limine verification/enrollment state and sign EFI files"
  echo "    enroll      Enroll keys into firmware (requires Setup Mode)"
  echo "    windows     Add Windows to Limine menu (first run) or reboot to Windows (after)"
  echo "    status      Show Secure Boot status and file verification"
  echo "    sign        Reassert Limine settings, repair config drift, and sign EFI files"
  echo "    help        Show this help"
  echo "    version     Show version"
  echo
  echo -e "  ${DIM}Note:${NC} This tool keeps ${BOLD}ENABLE_VERIFICATION=no${NC} while using Limine config enrollment."
  echo -e "        Package-triggered repair uses the pacman hooks; non-pacman drift uses the repo watcher."
  echo
  echo -e "  ${BOLD}Workflow${NC}"
  echo "    1. sudo omarchy-secureboot setup"
  echo "    2. Reboot -> BIOS -> enable Setup Mode (clear keys)"
  echo "    3. sudo omarchy-secureboot enroll"
  echo "    4. Reboot -> BIOS -> enable Secure Boot"
  echo "    5. sudo omarchy-secureboot windows   (adds menu entry; later runs reboot to Windows)"
  echo
}

# --- Dispatch ----------------------------------------------------------------

# Parse global flags
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --quiet) QUIET=true; export QUIET; shift ;;
    *)       break ;;
  esac
done

case "${1:-}" in
  setup)    cmd_setup ;;
  enroll)   cmd_enroll ;;
  windows)  cmd_windows ;;
  cleanup)  cmd_cleanup ;;
  sign)     cmd_sign ;;
  status)   cmd_status ;;
  help|--help|-h)  cmd_help ;;
  version|--version|-v) echo "omarchy-secureboot ${VERSION}" ;;
  *)
    cmd_help
    [[ -n "${1:-}" ]] && { fail "Unknown command: $1"; echo; exit 1; }
    ;;
esac
